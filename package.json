{
  "name": "@stzhu/prettier-plugin-tsconfig",
  "version": "0.7.2",
  "keywords": [
    "prettier",
    "tsconfig",
    "typescript"
  ],
  "license": "MIT",
  "author": "Steve Zhu <4130171+stevezhu@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevezhu/prettier-plugin-tsconfig.git"
  },
  "files": [
    "dist/*"
  ],
  "type": "module",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "format": "oxfmt && eslint . --fix",
    "generate": "tsx scripts/generateSortOrder.ts",
    "lint": "oxfmt --check && eslint .",
    "test": "tsc --noEmit && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@babel/types": "^7.28.5"
  },
  "devDependencies": {
    "@stzhu/eslint-config": "^0.10.0",
    "@stzhu/tsconfig": "^0.1.1",
    "@types/node": "^25.0.3",
    "cheerio": "^1.1.2",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "oxfmt": "^0.43.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "prettier": "^3.x"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0"
}
